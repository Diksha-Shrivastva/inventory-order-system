# ============================================================
#  Copy this file to ".env" before running docker compose.
#  Change the password to something non-default for any real
#  deployment. Nothing here is hardcoded in the app itself.
# ============================================================

# --- PostgreSQL ---
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=inventory

# --- Backend ---
# Comma-separated allowed origins, or "*" for all.
CORS_ORIGINS=*

# --- Frontend (build-time) ---
# Where the browser should reach the backend API.
# Local docker-compose: http://localhost:8000
VITE_API_URL=http://localhost:8000
